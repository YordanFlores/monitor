# WebSocket del broker Mosquitto (ajusta el path si usas /mqtt)
NEXT_PUBLIC_MQTT_WS_URL=ws://192.168.100.40:9001

# Unidades listadas en el dashboard (coma)
NEXT_PUBLIC_SCADA_UNITS=UNIDAD_01,UNIDAD_02

# Solo dev: saltar overlay de PIN inicial (ACCESO OMNITEC)
# NEXT_PUBLIC_OMNITEC_SKIP_LOGIN=1

# PIN de 4 dígitos que acepta la web sin esperar authOk en MQTT (mismo que el PLC)
# NEXT_PUBLIC_OMNITEC_LOGIN_PIN=1234
